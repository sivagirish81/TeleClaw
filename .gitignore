# TeleClaw template convention
# Commit only starter files as `.example*`.
# Local working copies must be untracked.

# Environment
.env
**/*.local

# Runbooks: ignore real manifests, keep examples
runbooks/**/*.yaml
runbooks/**/*.yml
!runbooks/**/*.example.yaml
!runbooks/**/*.example.yml

# Broker configs: ignore local real files, keep examples
broker/configs/*.yaml
broker/configs/*.yml
!broker/configs/*.example.yaml
!broker/configs/*.example.yml

# Teleport configs: ignore local real files, keep examples
teleport/configs/*.yaml
teleport/configs/*.yml
!teleport/configs/*.example.yaml
!teleport/configs/*.example.yml

# OpenClaw plugin local env/config
openclaw-plugin/.env
openclaw-plugin/*.yaml
openclaw-plugin/*.yml
!openclaw-plugin/*.example.yaml
!openclaw-plugin/*.example.yml

# OpenClaw + Teleport local runtime state
.openclaw/
.tsh/
.teleport/
tmp/

# Build artifacts
node_modules/
dist/
coverage/
broker/bin/
*.exe
*.test
*.out

# macOS/editor noise
.DS_Store
.idea/
.vscode/

# Local sensitive files
*.pem
*.key
